nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            // TODO: Re-enable snapshot testing once DENV workflow is fully implemented (Epic 5)
            // For now, just verify the pipeline executes successfully
            assert workflow.success
        }
    }
}
