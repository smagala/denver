nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assertAll(
                { assert snapshot(
                    path("${params.outdir}/pipeline_info/denver_software_mqc_versions.yml")
                ).match("versions") }
            )
        }
    }
}
