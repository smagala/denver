/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
    Contains test-specific parameters and settings.

    Container and executor configs are loaded via nf-configs profiles:
    - standard: local executor with resource limits
    - dev_reg: ECR docker registry + pipeline container overrides
    - test: pipeline's conf/test.config (test params and data paths)

    Set NF_CONFIGS_REPO env var to override the nf-configs location.
    Set NF_PIPELINE_REPO env var to "oamd-bio-denver" (defaults to this).
========================================================================================
*/

params {
    modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/denver'
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners
