/*
 * Docker configuration for OAMD hardened containers
 *
 * These containers are built with:
 *   - Non-root user: default (UID:GID 1001:1001) via USER directive
 *   - Read-only rootfs: WORKDIR /tmp, VOLUME /tmp
 *   - /tmp is the only writable directory (via container VOLUME)
 *
 * For local development, we run as the host user to avoid permission issues.
 * In production (AWS Batch), the container's USER directive will be used.
 */

docker {
    enabled = true
    // Run as host user for local development (avoids permission issues)
    runOptions = "-u \$(id -u):\$(id -g)"
    // Let Nextflow manage temp directory
    temp = 'auto'
}
