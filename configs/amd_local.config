/*
 * Local development configuration for OAMD Denver pipeline
 *
 * Combines container overrides and docker settings for local testing.
 *
 * Usage:
 *   nextflow run main.nf -profile test -c configs/amd_local.config
 *
 * Or run nf-test with:
 *   nf-test test -c configs/amd_local.config
 */

// Include container overrides
includeConfig "${projectDir}/configs/amd_containers.config"

// Include docker settings
includeConfig "${projectDir}/configs/amd_docker.config"
