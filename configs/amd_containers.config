/*
 * Container overrides for OAMD DENV (Denver) Pipeline
 *
 * This config provides custom container images from the OAMD ECR registry.
 * These containers are hardened builds based on ubuntu:24.04 with:
 *   - Read-only rootfs support (WORKDIR /tmp, VOLUME /tmp)
 *   - Non-root user (default, UID:GID 1001:1001)
 *   - s5cmd for AWS Fargate compatibility
 *
 * Usage: nextflow run main.nf -c configs/amd_containers.config ...
 */

// ECR registry prefix
def ECR_REGISTRY = "025066257930.dkr.ecr.us-east-1.amazonaws.com"

process {
    // ============================================================================
    // QUALITY CONTROL
    // ============================================================================

    withName: 'FASTQC' {
        container = "${ECR_REGISTRY}/oamd-bio-fastqc:0.12.2_07fd4b9_v0"
    }

    withName: 'MULTIQC' {
        container = "${ECR_REGISTRY}/oamd-bio-multiqc:1.31_7eb4de1_v0"
    }

    // ============================================================================
    // READ ALIGNMENT
    // ============================================================================

    withName: 'BWA_INDEX' {
        container = "${ECR_REGISTRY}/oamd-bio-bwa:0.7.19_28aafd7_v6"
    }

    withName: 'BWA_MEM' {
        container = "${ECR_REGISTRY}/oamd-bio-bwa:0.7.19_28aafd7_v6"
    }

    // ============================================================================
    // BAM PROCESSING
    // ============================================================================

    withName: 'SAMTOOLS_VIEW' {
        container = "${ECR_REGISTRY}/oamd-bio-samtools:1.22.1_f7896d2_v6"
    }

    withName: 'SAMTOOLS_SORT' {
        container = "${ECR_REGISTRY}/oamd-bio-samtools:1.22.1_f7896d2_v6"
    }

    withName: 'SAMTOOLS_INDEX' {
        container = "${ECR_REGISTRY}/oamd-bio-samtools:1.22.1_f7896d2_v6"
    }

    withName: 'SAMTOOLS_MPILEUP' {
        container = "${ECR_REGISTRY}/oamd-bio-samtools:1.22.1_f7896d2_v6"
    }

    // ============================================================================
    // PRIMER TRIMMING AND CONSENSUS
    // ============================================================================

    withName: 'IVAR_TRIM' {
        container = "${ECR_REGISTRY}/oamd-bio-ivar:1.4.4_f85436c_v0"
    }

    withName: 'IVAR_CONSENSUS' {
        container = "${ECR_REGISTRY}/oamd-bio-ivar:1.4.4_f85436c_v0"
    }

    withName: 'IVAR_VARIANTS' {
        container = "${ECR_REGISTRY}/oamd-bio-ivar:1.4.4_f85436c_v0"
    }

    // ============================================================================
    // COVERAGE ANALYSIS
    // ============================================================================

    withName: 'BEDTOOLS_GENOMECOV' {
        container = "${ECR_REGISTRY}/oamd-bio-bedtools:2.31.1_43a5f7b_v1"
    }

    // ============================================================================
    // SEQUENCE ANALYSIS AND ALIGNMENT
    // ============================================================================

    withName: 'NEXTCLADE_RUN' {
        container = "${ECR_REGISTRY}/oamd-bio-nextclade:3.18.1-cli_f556ccb_20251220"
    }

    withName: 'MAFFT_ALIGN' {
        container = "${ECR_REGISTRY}/oamd-bio-mafft:7.525_a2015e9_20251220"
    }
}
