config {
    // location for all nf-test tests
    testsDir "."

    // nf-test directory including temporary files for each test
    workDir System.getenv("NFT_WORKDIR") ?: ".nf-test"

    // Use nf-configs test configuration for profiles and container configs.
    // REQUIRED: Set NF_CONFIGS_REPO to the absolute path of the oamd-bio-nf-configs repo.
    // REQUIRED: Set NF_PIPELINE_REPO=oamd-bio-denver for container config lookups.
    // Example for local testing:
    //   export NF_CONFIGS_REPO=/path/to/oamd-bio-nf-configs
    //   export NF_PIPELINE_REPO=oamd-bio-denver
    //   nf-test test <test_path>
    configFile (System.getenv("NF_CONFIGS_REPO") ? System.getenv("NF_CONFIGS_REPO")+"/conf/tests/config/nextflow.config" : "../../configs/oamd-bio-nf-configs/conf/tests/config/nextflow.config")

    // ignore tests coming from the nf-core/modules repo
    ignore 'modules/nf-core/**/tests/*', 'subworkflows/nf-core/**/tests/*'

    // Profile selection:
    // - CI uses: "standard,dev_reg" (local executor, ECR containers) for module tests
    // - CI uses: "test,dev" (AWS Batch, dev environment) for pipeline tests
    // - Local: "test,dev_reg" (test profile + ECR docker registry)
    // NF_PROFILE env var overrides this setting.
    profile (System.getenv("NF_PROFILE") ?: "test,dev_reg")

    // list of filenames or patterns that should be trigger a full test run
    triggers 'nextflow.config', 'nf-test.config', 'conf/test.config', 'tests/nextflow.config', 'tests/.nftignore'

    // load the necessary plugins
    plugins {
        load "nft-utils@0.0.3"
    }
}
