
nextflow_process {

    name "Test Process NEXTCLADE_ALIGN"
    script "../main.nf"
    process "NEXTCLADE_ALIGN"

    tag "modules"
    tag "modules_phcore"
    tag "nextclade"
    tag "nextclade/align"

    test("sarscov2 default") {

        when {
            process {
                """
                input[0] = [[id: 'test'],
                    file(params.nfcore_modules_testdata_base_path + '/genomics/sarscov2/genome/genome-ena.fasta', checkIfExists: true)
                    ]
                input[1] = file(params.nfcore_modules_testdata_base_path + '/genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.alignment,
                    process.out.csv,
                    process.out.versions
                    ).match() }
            )
        }
    }

    test("sarscov2 default-stub") {
        options '-stub'

        when {
            process {
                """
                input[0] = [[id: 'test'],
                    file(params.nfcore_modules_testdata_base_path + '/genomics/sarscov2/genome/genome-ena.fasta', checkIfExists: true)
                    ]
                input[1] = file(params.nfcore_modules_testdata_base_path + '/genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
