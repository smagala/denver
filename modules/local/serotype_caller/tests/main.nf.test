nextflow_process {

    name "Test Process SEROTYPE_CALLER"
    script "../main.nf"
    process "SEROTYPE_CALLER"

    tag "modules"
    tag "modules_local"
    tag "serotype_caller"

    test("stub test") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test', serotype: 'DENV1' ],
                    file("${projectDir}/tests/data/denv1_R1.fastq.gz")  // placeholder
                ]
                input[1] = file("${projectDir}/../assets/denver/1.0.0/DENV1.bed")
                input[2] = 0.5
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.serotype_call },
                { assert process.out.versions }
            )
        }
    }
}
