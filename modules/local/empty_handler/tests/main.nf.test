nextflow_process {

    name "Test Process EMPTY_HANDLER"
    script "../main.nf"
    process "EMPTY_HANDLER"

    tag "modules"
    tag "modules_local"
    tag "empty_handler"

    test("stub test") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test', serotype: 'DENV1' ],
                    'DENV1'
                ]
                input[1] = 10
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.virustype_info },
                { assert process.out.variants },
                { assert process.out.versions }
            )
        }
    }
}
