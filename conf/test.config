/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run cdcent/oamd-bio-denver -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

// Generate samplesheet with paths to shared test data repository.
// nf-schema resolves paths relative to the launch directory (not the samplesheet
// location), so relative paths in the CSV break under nf-test. Writing to a
// separate generated file avoids dirtying the committed template.
def test_data_base = "https://raw.githubusercontent.com/CDCgov/oamd-bio-test-data/denver"
def test_data_fastq = "${test_data_base}/data/genomics/dengue/fastq"
def local_data = "${projectDir}/tests/data"
def generated = new File("${local_data}/.generated_samplesheet.csv")
generated.text = """\
sample,fastq_1,fastq_2,ct
denv1_test,${test_data_fastq}/denv1_R1.fastq.gz,${test_data_fastq}/denv1_R2.fastq.gz,25.5
"""

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data - generated at config parse time with remote test data URLs
    input = "${local_data}/.generated_samplesheet.csv"

    // DENV references - uses bundled assets
    references_base = "${projectDir}/../assets/denver/1.0.0"

    // Use only DENV1 for faster testing
    serotypes_file = "${projectDir}/tests/data/refs_test.txt"

    // Lower thresholds for test data
    min_depth           = 5
    consensus_threshold = 0.6
    coverage_threshold  = 0.1

    // Disable iGenomes
    igenomes_ignore = true
}
