/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run smagala/denver -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data - dynamically generate samplesheet with absolute paths
    // This ensures the paths are correct regardless of working directory
    test_data_dir = "${projectDir}/tests/data"
    input = "${projectDir}/tests/data/samplesheet.csv"

    // DENV references - uses bundled assets
    references_base = "${projectDir}/../assets/denver/1.0.0"

    // Use only DENV1 for faster testing
    serotypes_file = "${projectDir}/tests/data/refs_test.txt"

    // Lower thresholds for test data
    min_depth           = 5
    consensus_threshold = 0.6
    coverage_threshold  = 0.1

    // Disable iGenomes
    igenomes_ignore = true
}
